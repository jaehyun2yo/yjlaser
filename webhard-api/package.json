      "path-to-regexp@0": "0.1.13",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "qs": "6.15.2",
      "socket.io-parser": "4.2.6",
      "uuid": "11.1.1",
      "ws": "8.21.0"
    }
  }
}
