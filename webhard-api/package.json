{
  "name": "webhard-api",
  "version": "1.0.0",
  "description": "NestJS Webhard API",
  "author": "YJLaser",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:security": "jest --runInBand src/auth/guards/recovery-api-key.guard.spec.ts src/integration/auth/api-key.guard.spec.ts src/mail/mail.service.spec.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "npx prisma generate",
    "prisma:db:pull": "npx prisma db pull",
    "prisma:studio": "npx prisma studio",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:status": "npx prisma migrate status",
    "migrate:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "r2:dry-run-delete": "npx tsx scripts/dry-run-non-portfolio-r2-delete.ts",
    "smoke:device-auth:dev": "tsx scripts/device-auth-dev-lifecycle-smoke.ts",
    "control:device-auth:dev-client-e2e": "tsx scripts/device-auth-dev-client-e2e-control.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^6.1.0",
    "@smithy/node-http-handler": "^4.7.4",
    "@types/compression": "^1.8.1",
    "archiver": "^7.0.1",
    "cache-manager": "^7.2.8",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
