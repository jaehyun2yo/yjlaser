{
  "name": "nextjs-prec-1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- next dev --turbopack",
    "dev:env": "next dev --turbopack",
    "dev:webpack": "doppler run -- next dev",
    "build": "next build --turbopack",
    "start": "next start -p 3100",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky install",
    "postinstall": "npm rebuild sharp || npm install --include=optional sharp",
    "build:test": "npm run build && npm rebuild sharp && npm run start",
    "build:clean": "rm -rf .next && npm run build",
    "preview": "npm run build && npm run start",
    "rebuild:sharp": "npm rebuild sharp",
    "vercel:dev": "vercel dev",
    "vercel:build": "vercel build",
    "vercel:preview": "vercel dev",
    "webhard:install": "cd webhard-api && pnpm install",
    "webhard:dev": "cd webhard-api && doppler run -- pnpm start:dev",
    "webhard:build": "cd webhard-api && pnpm build",
    "webhard:start": "cd webhard-api && pnpm start:prod",
    "webhard:prisma": "cd webhard-api && pnpm prisma:generate",
    "dev:all": "start cmd /k pnpm webhard:dev && pnpm dev:webpack",
    "doppler:pull": "doppler secrets download --project yjlaser --config dev --no-file --format env > .env.local",
    "setup:dev": "bash scripts/setup-dev.sh"
  },
